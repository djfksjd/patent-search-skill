{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/djfksjd/patent-search-skill/references/claim_chart_schema.json",
  "title": "patent-search claim chart v1",
  "description": "Claim chart 산출물 스키마. 행(한정·관계) × 열(문헌) 셀에 판정값과 근거를 기록한다. E/I/P는 citation(문헌번호+문단/청구항 번호+직접 인용+URL+확인일) 필수, I는 inherency_rationale 추가 필수. 검증은 scripts/claim_chart_validate.py.",
  "type": "object",
  "required": ["schema_version", "chart_type", "rows", "columns", "cells"],
  "additionalProperties": true,
  "properties": {
    "schema_version": { "const": 1 },
    "chart_type": {
      "description": "patentability: 내 청구 예정 한정(행) × 선행문헌(열). fto: 상대 독립항 한정(행) × 내 실시 형태(열) — 방향이 반대이므로 겸용 금지.",
      "enum": ["patentability", "fto"]
    },
    "title": { "type": "string" },
    "created_at": { "type": "string" },
    "rows": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "limitation"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "limitation": {
            "description": "원자화된 한정 또는 관계(예: 'A가 B의 출력에 따라 C를 제어한다')",
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "columns": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "document_number"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "document_number": {
            "description": "문헌번호(출원/공개/등록번호) 또는 fto 차트의 '내 실시 형태' 식별자",
            "type": "string",
            "minLength": 1
          },
          "label": { "type": "string" }
        }
      }
    },
    "cells": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["row", "column", "value"],
        "properties": {
          "row": { "description": "rows[].id 참조", "type": "string" },
          "column": { "description": "columns[].id 참조", "type": "string" },
          "value": {
            "description": "E=명시적 개시, I=내재적 개시(필연 — inherency_rationale 필수), P=부분/상위개념/불명확, N=검토 범위에서 미발견(부재 단정 아님), ?=원문/번역 확인 필요",
            "enum": ["E", "I", "P", "N", "?"]
          },
          "citation": {
            "description": "E/I/P 필수. 모든 필드 비어있지 않아야 한다.",
            "type": "object",
            "required": ["document_number", "locator", "quote", "url", "verified_at"],
            "properties": {
              "document_number": { "type": "string", "minLength": 1 },
              "locator": {
                "description": "문단/청구항/도면 번호(예: '[0042]', '청구항 3', 'Fig. 2')",
                "type": "string",
                "minLength": 1
              },
              "quote": {
                "description": "원문 직접 인용(짧게) — 요약·의역만으로는 불충분",
                "type": "string",
                "minLength": 1
              },
              "url": { "type": "string", "minLength": 1 },
              "verified_at": {
                "description": "원문 확인일(YYYY-MM-DD)",
                "type": "string",
                "minLength": 1
              }
            }
          },
          "inherency_rationale": {
            "description": "I 전용 필수 — 그 개시로부터 해당 한정이 '필연적으로' 따라온다는 논거",
            "type": "string",
            "minLength": 1
          },
          "note": { "type": "string" }
        },
        "allOf": [
          {
            "if": { "properties": { "value": { "enum": ["E", "I", "P"] } } },
            "then": { "required": ["citation"] }
          },
          {
            "if": { "properties": { "value": { "const": "I" } } },
            "then": { "required": ["inherency_rationale"] }
          }
        ]
      }
    }
  }
}
